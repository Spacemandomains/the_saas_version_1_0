{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product Requirement Document",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "overview": { "type": "string" },
    "problem": { "type": "string" },
    "goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "user_stories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "as_a": { "type": "string" },
          "i_want": { "type": "string" },
          "so_that": { "type": "string" }
        },
        "required": ["as_a", "i_want", "so_that"]
      }
    },
    "requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["title", "overview", "problem", "goals", "user_stories"]
}
