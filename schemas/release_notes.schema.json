{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Release Notes",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "version": { "type": "string" },
    "release_date": { "type": "string" },
    "summary": { "type": "string" },
    "new_features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "feature": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["feature", "description"]
      }
    },
    "improvements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bug_fixes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "breaking_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "known_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "upgrade_instructions": { "type": "string" }
  },
  "required": ["title", "version", "summary", "new_features"]
}
