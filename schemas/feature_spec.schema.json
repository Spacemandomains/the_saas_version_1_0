{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature Specification",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "feature_summary": { "type": "string" },
    "target_users": {
      "type": "array",
      "items": { "type": "string" }
    },
    "problem_statement": { "type": "string" },
    "proposed_solution": { "type": "string" },
    "functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "requirement": { "type": "string" },
          "priority": { "type": "string" }
        },
        "required": ["id", "requirement", "priority"]
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ui_ux_considerations": { "type": "string" },
    "edge_cases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "success_metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timeline_estimate": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["title", "feature_summary", "problem_statement", "proposed_solution", "functional_requirements", "success_metrics"]
}
